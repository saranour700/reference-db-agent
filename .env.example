# Reference DB Intelligence Agent — Environment Variables

# === Optional: Bright Data MCP ===
# Only used as last-resort fallback when all free methods fail.
# Requires explicit --bright-data flag to activate.
BRIGHT_DATA_API_KEY=

# === Optional: Proxy Settings ===
# Set if using a residential proxy for Cloudflare bypass.
HTTP_PROXY=
HTTPS_PROXY=

# === Scraping Settings ===
# Default delay between requests (seconds)
REQUEST_DELAY_SECONDS=1.5

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=5

# Request timeout (seconds)
REQUEST_TIMEOUT_SECONDS=15

# === Playwright Settings ===
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
